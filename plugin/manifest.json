{
  "id": "maimai_vrchat_osc",
  "name": "maimai DX · VRChat OSC",
  "version": "1.4.1",
  "sdk": "1",
  "author": "XiaoLan9999",
  "description": "持续发送 maimai DX 主界面、选歌、游玩与结算状态到 VRChat OSC，不包含郊狼设备触发。",
  "homepage": "https://github.com/XiaoLan9999/maimai-vrchat-osc",
  "entry": "main.py",
  "capabilities": { "startup_check": true },
  "config_schema": [
    {
      "section": "自动安装",
      "fields": [
        { "key": "game_package", "type": "path", "path_kind": "dir", "label": "游戏 Package 目录", "default": "", "description": "包含 Sinmai.exe 的 Package 目录；留空时从运行中的游戏自动识别" },
        { "key": "auto_detect_game", "type": "bool", "label": "从运行中的游戏自动识别目录", "default": true },
        { "key": "auto_install_bridge", "type": "bool", "label": "自动安装/更新 MaiDGBridge", "default": true, "description": "安装前备份已有 DLL 和配置；游戏运行中不会覆盖旧版 DLL" }
      ]
    },
    {
      "section": "连接",
      "fields": [
        { "key": "endpoint", "type": "text", "label": "MaiDGBridge 数据端点", "default": "http://127.0.0.1:8891/events", "description": "游戏 Mods 目录中的桥接 DLL 提供的本机 SSE 地址" },
        { "key": "debug", "type": "bool", "label": "调试日志", "default": false }
      ]
    },
    {
      "section": "VRChat OSC",
      "fields": [
        { "key": "osc_enabled", "type": "bool", "label": "启用 VRChat Chatbox", "default": false, "description": "持续发送主界面、选歌、正在游玩与结算状态；VRChat 中也需要启用 OSC" },
        { "key": "osc_host", "type": "text", "label": "VRChat 电脑 IPv4", "default": "127.0.0.1", "description": "同机使用 127.0.0.1；局域网另一台电脑填写其 IPv4" },
        { "key": "osc_port", "type": "text", "label": "VRChat OSC 端口", "default": "9000", "description": "VRChat 默认接收端口为 UDP 9000" },
        { "key": "osc_player", "type": "text", "label": "显示玩家", "default": "1", "description": "填写 1 或 2" },
        { "key": "osc_update_interval", "type": "duration", "label": "刷新间隔", "default": 1.0, "description": "限制为 0.5 至 30 秒" },
        { "key": "osc_show_artist", "type": "bool", "label": "显示 Artist", "default": true },
        { "key": "osc_show_judgements", "type": "bool", "label": "显示连击与 MISS", "default": true },
        { "key": "osc_show_result", "type": "bool", "label": "显示曲目结算", "default": true },
        { "key": "osc_notification", "type": "bool", "label": "播放 Chatbox 通知音", "default": false }
      ]
    }
  ]
}
